    <title>昨日之歌</title>
    <link>https://huozhixue.github.io/anime/sing-yesterday-for-me/</link>
    <pubDate>Sat, 04 Apr 2020 00:00:00 &#43;0800</pubDate>
    <author>作者</author>
    <guid>https://huozhixue.github.io/anime/sing-yesterday-for-me/</guid>
    <description><![CDATA[<p>共 12 话</p>
<div class="media" id="id-1" type="tv"><input type="text" />
			<button class="media-jump"><i class="fa fa-hand-point-right" aria-hidden="true"></i></button><button class="media-prev"><i class="fa fa-backward" aria-hidden="true"></i></button>
		<button class="media-next"><i class="fa fa-forward" aria-hidden="true"></i></button>
		<a href="#id-1"></a>
		<div></div>
	</div>
	<script>
		var random = "";
		var data = $.ajax({url: "/tv\/Sing_Yesterday_For_Me",async:false}).responseText.split(/[\n\r]+/);
		var len = data.length;
		for (let i = 0; i < len; i++) {
			let pair = data[i].split(/\t/);
			let url = pair[0];
			if (url.substr(0, 2) == 'BV') {
				url = "https://player.bilibili.com/player.html?high_quality=1&bvid=" + url;
			}
			else if (url.substr(0, 4) != 'http' ) {
				if (url.substr(0, 3) == 'id_'){
					url = "https://v.youku.com/v_show/" + url + ".html";
				}
				else if (url.substr(0, 2) == 'v_'){
					url = "https://www.iqiyi.com/" + url + ".html";
				}
				url = "https://jx.aidouer.net/?url=" + url;
			};
			pair[0] = url;
			pair[1] = '#'+(i+1)+' '+pair[1];
			data[i] = pair;
		}
		if (random){
			var t = new Date();
			var cur = Math.floor(t / (24 * 3600 * 1000)) % len;
			var tmp = data[0];
			data[0] = data[cur];
			data[cur] = tmp;
			for (let i = 1; i < len - 1; i++) {
				var j = parseInt(i + Math.random() * (len - i));
				var temp = data[i];
				data[i] = data[j];
				data[j] = temp;
			}
		}
		window.config.media["id-1"] = data;
	</script>]]></description>
